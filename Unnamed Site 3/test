<!DOCTYPE html>

<html>
<head>
<meta charset="UTF-8">
<title>Photobooth</title>

<style>
body{
font-family:Arial;
display:flex;
justify-content:center;
align-items:center;
gap:40px;
margin-top:40px;
background:#f4efe6;
}

#photobooth{
width:300px;
height:500px;
background:white;
position:relative;
padding:10px;
box-shadow:0 10px 25px rgba(0,0,0,0.2);
}

.grid{
display:grid;
grid-template-rows:1fr 1fr;
gap:10px;
height:80%;
}

canvas{
width:100%;
height:100%;
background:#ddd;
}

#frameOverlay{
position:absolute;
top:0;
left:0;
width:100%;
height:100%;
pointer-events:none;
}

#cameraBox{
text-align:center;
}

video{
width:260px;
transform:scaleX(-1);
border-radius:10px;
}

#countdown{
font-size:40px;
margin-top:10px;
}

button{
margin-top:10px;
padding:10px 20px;
background:black;
color:white;
border:none;
cursor:pointer;
}
</style>

</head>

<body>

<div id="photobooth">
<div class="grid">
<canvas id="photo1" width="300" height="200"></canvas>
<canvas id="photo2" width="300" height="200"></canvas>
</div>
<img id="frameOverlay" src="frame.png">
</div>

<div id="cameraBox">
<video id="video" autoplay playsinline></video>
<div id="countdown"></div>
<button onclick="startBooth()">Start</button>
</div>

<script>

const video = document.getElementById("video");
let stream;
let shot = 1;

/* START CAMERA ONLY WHEN USER CLICKS */
async function startBooth(){

try{
stream = await navigator.mediaDevices.getUserMedia({ video:true });
video.srcObject = stream;
await video.play();

shot = 1;
setTimeout(takePhoto,500);

}catch(err){
alert("Camera error: " + err);
}

}

function takePhoto(){

if(shot > 2){
finishBooth();
return;
}

let count = 3;
const countdown = document.getElementById("countdown");

const timer = setInterval(()=>{

countdown.innerText = count;
count--;

if(count < 0){

clearInterval(timer);
countdown.innerText="";

const canvas = document.getElementById("photo"+shot);
const ctx = canvas.getContext("2d");

/* mirror capture */
ctx.save();
ctx.scale(-1,1);
ctx.drawImage(video,-canvas.width,0,canvas.width,canvas.height);
ctx.restore();

shot++;

setTimeout(takePhoto,800);

}

},1000);

}

function finishBooth(){

const finalCanvas = document.createElement("canvas");
finalCanvas.width = 300;
finalCanvas.height = 500;

const ctx = finalCanvas.getContext("2d");

/* background */
ctx.fillStyle="white";
ctx.fillRect(0,0,300,500);

const p1 = document.getElementById("photo1");
const p2 = document.getElementById("photo2");

ctx.drawImage(p1,0,0,300,200);
ctx.drawImage(p2,0,210,300,200);

/* overlay frame */
const frame = new Image();

frame.onload = function(){

ctx.drawImage(frame,0,0,300,500);

/* save + redirect */
const imageData = finalCanvas.toDataURL();
localStorage.setItem("photostrip", imageData);

/* stop camera */
if(stream){
stream.getTracks().forEach(track => track.stop());
}

window.location.href = "result.html";

};

frame.src = "frame.png";

}

</script>

</body>
</html>
